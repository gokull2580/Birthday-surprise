rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read, write to the users collection
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
